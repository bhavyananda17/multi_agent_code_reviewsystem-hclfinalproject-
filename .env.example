# Multi-Agent Code Review System - Environment Configuration
# Copy this to .env and fill in your values

# Groq API (REQUIRED)
GROQ_API_KEY=your_groq_api_key_here
GROQ_BASE_URL=https://api.groq.com/openai

# Model Configuration
# Specialist agents + docs/onboarding: 8b-instant (fast, cheap)
# Synthesis agent: 70b-versatile (needs higher reasoning)
MULTIAGENT_MODEL_TRIAGE=llama-3.1-8b-instant
MULTIAGENT_MODEL_SECURITY=llama-3.1-8b-instant
MULTIAGENT_MODEL_LOGIC=llama-3.1-8b-instant
MULTIAGENT_MODEL_PERFORMANCE=llama-3.1-8b-instant
MULTIAGENT_MODEL_MODERNIZATION=llama-3.1-8b-instant
MULTIAGENT_MODEL_SYNTHESIS=llama-3.3-70b-versatile
MULTIAGENT_MODEL_DOCUMENTATION=llama-3.1-8b-instant
MULTIAGENT_MODEL_ONBOARDING=llama-3.1-8b-instant

# Rate Limits (Groq free tier: 30 RPM, 6000 TPM)
RPM_LIMIT=30
MULTIAGENT_TPM_LIMIT=6000